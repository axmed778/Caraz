{
  "name": "caraz",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @caraz/database generate",
    "db:push": "pnpm --filter @caraz/database push",
    "db:migrate": "pnpm --filter @caraz/database migrate",
    "db:studio": "pnpm --filter @caraz/database studio",
    "db:seed": "pnpm --filter @caraz/database seed"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
