# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/caraz?sslmode=require"

# JWT
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="caraz-images"
R2_PUBLIC_URL="https://cdn.yourdomain.az"

# Resend (email)
RESEND_API_KEY=""

# App
API_PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
